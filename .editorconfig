# https://editorconfig.org — wird vom GitHub-Webeditor und fast allen
# Editoren (VSCode mit Extension) automatisch respektiert.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown: trailing whitespace nicht trimmen (zwei Leerzeichen am
# Zeilenende bedeuten in Markdown einen harten Zeilenumbruch).
[*.md]
trim_trailing_whitespace = false
