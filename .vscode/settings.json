{
  // Editor-Basics
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.rulers": [100],
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  // Jekyll-Layouts und Includes sind HTML mit Liquid-Tags — als Liquid
  // erkennen, damit die Shopify-Liquid-Extension greift und der HTML-
  // Formatter nicht die Liquid-Blöcke zerreißt.
  "files.associations": {
    "_layouts/*.html": "liquid",
    "_includes/*.html": "liquid",
    "404.html": "liquid"
  },

  // Markdown: weicher Zeilenumbruch, keine Autovervollständigung beim Schreiben
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    },
    "files.trimTrailingWhitespace": false
  },

  // YAML-Dateien (_data/*.yml, _config.yml) — 2 Leerzeichen
  "[yaml]": {
    "editor.tabSize": 2
  },

  // RedHat-YAML-Extension: keine Schemata automatisch von schemastore.org
  // ziehen. Unsere _data/*.yml sind freies Jekyll-Datenmaterial — jedes
  // Auto-Schema erzeugt nur falsche Fehler.
  "yaml.schemas": {},
  "yaml.schemaStore.enable": false,

  // Jekyll-Layouts als reines HTML: Formatter aus (siehe oben), falls
  // irgendwo doch als HTML erkannt.
  "[html]": {
    "editor.formatOnSave": false
  },

  // Build-Artefakte aus Suche ausblenden
  "search.exclude": {
    "_site": true,
    ".jekyll-cache": true,
    "vendor": true
  },

  // Spellchecker-Sprache (DE zuerst, dann EN)
  "cSpell.language": "de,en"
}
